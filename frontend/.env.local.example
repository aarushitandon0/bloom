# ── Bloom Frontend — environment variables ─────────────────
# Copy this file to .env.local and fill in your project values.
# Supabase: https://supabase.com/dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── Backend API URL ──────────────────────────────────────────
# Point to your local backend (or deployed URL in production)
VITE_API_URL=http://localhost:4000

# ── Optional: override the OAuth redirect URL in development ──
# Leave blank to use window.location.origin (auto-detected)
# VITE_SUPABASE_REDIRECT_URL=http://localhost:5173
