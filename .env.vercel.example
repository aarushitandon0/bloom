# ── Bloom — Vercel Environment Variables ──────────────────────
# Add these in Vercel Dashboard → Settings → Environment Variables
#
# Required for the serverless API functions (backend):
SUPABASE_URL=https://cktguyybhkmnpqaudqag.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NODE_ENV=production

# Required for the frontend build:
VITE_SUPABASE_URL=https://cktguyybhkmnpqaudqag.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# VITE_API_URL is NOT needed — frontend uses same domain on Vercel
